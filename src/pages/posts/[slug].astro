---
import { getCollection, render } from 'astro:content';
import { SITE } from '../../lib/site';
import '../../styles/global.css';

export async function getStaticPaths() {
  const entries = await getCollection('posts');
  // Canonical ordering: pinned first, then date descending (matches the index)
  const ordered = [...entries].sort((a, b) => {
    if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
    return b.data.date.localeCompare(a.data.date);
  });
  return ordered.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prevSlug: ordered[i - 1]?.id ?? null,
      nextSlug: ordered[i + 1]?.id ?? null
    }
  }));
}

const { entry, prevSlug, nextSlug } = Astro.props;
const { Content } = await render(entry);
const { title, date, author, tags, summary } = entry.data;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={summary} />
    <title>{title} // jless-blog</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    data-slug={entry.id}
    data-prev-url={prevSlug ? `/posts/${prevSlug}/` : ''}
    data-next-url={nextSlug ? `/posts/${nextSlug}/` : ''}
  >
    <div class="pager-header">Reader: {title}</div>
    <main class="pager-main" id="pager-main">
      <article class="reader-post" data-pagefind-body>
        <h1>{title}</h1>
        <div class="reader-meta">
          <span><span class="reader-meta-label">Author:</span> {author}</span>
          <span><span class="reader-meta-label">Date:</span> {date}</span>
          <span
            ><span class="reader-meta-label">Tags:</span>
            {tags.map((tag) => <span class="reader-tag">{tag}</span>)}
          </span>
        </div>
        <div class="reader-body">
          <Content />
        </div>
      </article>
    </main>
    <footer class="app-footer">
      <div class="status-left">
        <span class="app-logo" style="margin-right: 16px;">jless-blog<span>.json</span></span>
        <span>MODE: PAGER</span>
        <span class="status-hint">[[ / ]] Prev/Next</span>
        <span class="status-hint-read">[q / Esc] Close Article</span>
      </div>
      <div class="status-right">
        <span>focused-noether v{SITE.version}</span>
      </div>
    </footer>

    <script>
      const main = document.getElementById('pager-main')!;
      const { slug, prevUrl, nextUrl } = document.body.dataset;

      // Let the index restore its selection to this post on return
      if (slug) sessionStorage.setItem('jless:lastPost', slug);

      let keyBuffer = '';
      let gTimer: any;

      window.addEventListener('keydown', (e) => {
        if (e.ctrlKey || e.metaKey || e.altKey) return;
        const k = e.key;
        const pendingG = keyBuffer === 'g';
        if (k !== 'g' && pendingG) {
          keyBuffer = '';
          clearTimeout(gTimer);
        }

        let handled = true;
        if (k === 'j' || k === 'ArrowDown') {
          main.scrollTop += 40;
        } else if (k === 'k' || k === 'ArrowUp') {
          main.scrollTop -= 40;
        } else if (k === ' ' || k === 'PageDown' || k === 'f') {
          main.scrollTop += main.clientHeight - 40;
        } else if (k === 'PageUp' || k === 'b') {
          main.scrollTop -= main.clientHeight - 40;
        } else if (k === 'd') {
          main.scrollTop += Math.floor(main.clientHeight / 2);
        } else if (k === 'u') {
          main.scrollTop -= Math.floor(main.clientHeight / 2);
        } else if (k === 'g') {
          if (pendingG) {
            keyBuffer = '';
            clearTimeout(gTimer);
            main.scrollTop = 0;
          } else {
            keyBuffer = 'g';
            clearTimeout(gTimer);
            gTimer = setTimeout(() => {
              keyBuffer = '';
            }, 500);
          }
        } else if (k === 'G' || k === 'End') {
          main.scrollTop = main.scrollHeight;
        } else if (k === 'Home') {
          main.scrollTop = 0;
        } else if (k === 'q' || k === 'Escape') {
          window.location.href = '/';
        } else if (k === '[' && prevUrl) {
          window.location.href = prevUrl;
        } else if (k === ']' && nextUrl) {
          window.location.href = nextUrl;
        } else {
          handled = false;
        }
        if (handled) e.preventDefault();
      });

      function adjustSidenotes() {
        const body = document.querySelector('.reader-body');
        if (!body) return;

        if (window.innerWidth < 1200) {
          body.querySelectorAll('.sidenote').forEach((note) => {
            if (note instanceof HTMLElement) note.style.top = '';
          });
          return;
        }

        const leftNotes = Array.from(body.querySelectorAll('.sidenote-left')) as HTMLElement[];
        const rightNotes = Array.from(body.querySelectorAll('.sidenote-right')) as HTMLElement[];

        const sortAndReset = (notes: HTMLElement[]) => {
          notes.forEach((note) => (note.style.top = ''));
          return notes.sort((a, b) => a.offsetTop - b.offsetTop);
        };

        const adjust = (notes: HTMLElement[]) => {
          let lastBottom = 0;
          notes.forEach((note) => {
            let top = note.offsetTop;
            if (top < lastBottom) {
              top = lastBottom + 12; // 12px margin gap
              note.style.top = `${top}px`;
            }
            lastBottom = top + note.offsetHeight;
          });
        };

        adjust(sortAndReset(leftNotes));
        adjust(sortAndReset(rightNotes));
      }

      function initSidenotes() {
        const body = document.querySelector('.reader-body');
        const footnotesSection = document.querySelector('.footnotes');
        if (!body || !footnotesSection) return;

        const footnoteItems = footnotesSection.querySelectorAll('ol > li');
        footnoteItems.forEach((li) => {
          const id = li.getAttribute('id');
          if (!id) return;

          const refLink = body.querySelector(`a[href="#${id}"]`);
          if (!refLink) return;

          const refParent = refLink.closest('sup') || refLink;
          let content = li.innerHTML;

          // Strip the GFM backreference link
          content = content.replace(/<a\s+[^>]*class="[^"]*(data-)?footnote-backref"[^>]*>.*?<\/a>/gi, '');
          content = content.replace(/<a\s+[^>]*data-footnote-backref[^>]*>.*?<\/a>/gi, '');
          content = content.replace(/↩/g, '').trim();

          // Check for direction prefix (default: right)
          let side = 'right';
          const leftPattern = /^<p>\s*(L|left)\s*:\s*(.*)/i;
          const leftMatch = content.match(leftPattern);
          if (leftMatch) {
            side = 'left';
            content = content.replace(leftPattern, '<p>$2');
          } else {
            const leftMatchNoP = content.match(/^\s*(L|left)\s*:\s*(.*)/i);
            if (leftMatchNoP) {
              side = 'left';
              content = leftMatchNoP[2];
            }
          }

          const rightPattern = /^<p>\s*(R|right)\s*:\s*(.*)/i;
          const rightMatch = content.match(rightPattern);
          if (rightMatch) {
            side = 'right';
            content = content.replace(rightPattern, '<p>$2');
          } else {
            const rightMatchNoP = content.match(/^\s*(R|right)\s*:\s*(.*)/i);
            if (rightMatchNoP) {
              side = 'right';
              content = rightMatchNoP[2];
            }
          }

          // Create the sidenote container
          const sidenote = document.createElement('span');
          sidenote.className = `sidenote sidenote-${side}`;
          sidenote.innerHTML = content;

          // Insert directly after footnote reference anchor parent
          refParent.parentNode?.insertBefore(sidenote, refParent.nextSibling);
        });

        // Hide original footnotes
        if (footnotesSection instanceof HTMLElement) {
          footnotesSection.style.display = 'none';
        }

        // Adjust vertical positions of sidenotes to prevent overlaps
        adjustSidenotes();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSidenotes);
      } else {
        initSidenotes();
      }

      window.addEventListener('resize', adjustSidenotes);
      window.addEventListener('load', adjustSidenotes);
    </script>
  </body>
</html>
